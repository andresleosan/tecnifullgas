{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/mimo-v2-5-free",
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "git push --force*": "deny",
      "sudo *": "ask",
      "*migrate*": "ask",
      "*--prod*": "ask",
      "cat *.env*": "ask",
      "cat *secret*": "ask",
      "cat *credential*": "ask",
      "env": "ask",
      "printenv*": "ask",
      "history": "ask"
    }
  },
  "agent": {
    "Cronos V3": {
      "description": "Cronos 3.3.3 — agente único: arquitectura, backend, frontend, datos, integraciones, seguridad, QA, rendimiento y despliegue",
      "mode": "primary",
      "model": "opencode/mimo-v2-5-free",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    }
  }
}
